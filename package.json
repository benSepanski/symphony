{
  "name": "symphony",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:web": "vite",
    "build": "pnpm build:web && tsc",
    "build:web": "vite build",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "eval": "vitest run --config vitest.eval.config.ts",
    "all": "pnpm typecheck && pnpm fmt:check && pnpm lint && pnpm test && pnpm eval"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "better-sqlite3": "^11.7.0",
    "commander": "^13.1.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.6",
    "liquidjs": "^10.21.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.19.0",
    "fast-check": "^4.7.0",
    "prettier": "^3.4.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.23.0",
    "vite": "^8.0.8",
    "vitest": "^3.0.5"
  },
  "packageManager": "pnpm@10.16.1",
  "pnpm": {
    "overrides": {
      "esbuild@<0.25.0": ">=0.25.0"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
